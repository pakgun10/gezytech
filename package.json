{
  "name": "gezytech",
  "version": "1.9.0",
  "type": "module",
  "description": "Gezy — self-hosted AI agent platform with persistent identity, memory, tools, and collaboration",
  "license": "MIT",
  "author": "marlburrow",
  "homepage": "https://github.com/pgun/gezy",
  "repository": {
    "type": "git",
    "url": "https://github.com/pgun/gezy.git"
  },
  "bugs": {
    "url": "https://github.com/pgun/gezy/issues"
  },
  "keywords": [
    "ai-agents",
    "agents",
    "self-hosted",
    "llm",
    "multi-agent",
    "bun",
    "hono",
    "react",
    "sqlite",
    "gezy"
  ],
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0"
  },
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"bun run dev:client\" \"bun run dev:server\"",
    "dev:client": "vite",
    "dev:server": "bun scripts/dev-server.ts",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 vite build",
    "start": "bun src/server/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun scripts/migrate.ts",
    "db:snapshot": "bun scripts/db-snapshot.ts create",
    "db:snapshot:list": "bun scripts/db-snapshot.ts list",
    "db:snapshot:restore": "bun scripts/db-snapshot.ts restore",
    "test": "bun test $(find ./src ./packages/sdk/src ./packages/create-hivekeep-plugin ./plugins -name '*.test.ts' | sort)",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=8192 tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "fflate": "^0.8.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0",
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.139",
    "@anthropic-ai/sdk": "^0.81.0",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/view": "^6.43.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@gezy/sdk": "workspace:*",
    "@hono/node-server": "^1.19.9",
    "@hookform/resolvers": "^5.2.2",
    "@lobehub/icons": "^5.0.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@mozilla/readability": "^0.6.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.0",
    "@types/mdast": "^4.0.4",
    "@uiw/react-codemirror": "^4.25.4",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-auth": "^1.4.18",
    "better-sqlite3": "^12.6.2",
    "bun-pty": "^0.4.9",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "country-flag-icons": "^1.6.17",
    "croner": "^10.0.1",
    "cronstrue": "^3.12.0",
    "docx": "^9.7.1",
    "drizzle-orm": "^0.45.1",
    "exceljs": "^4.4.0",
    "googleapis": "^173.0.0",
    "gpt-tokenizer": "^3.4.0",
    "hono": "^4.12.0",
    "i18next": "^25.8.11",
    "ical.js": "^2.2.1",
    "imapflow": "^1.3.4",
    "jszip": "^3.10.1",
    "katex": "^0.17.0",
    "linkedom": "^0.18.12",
    "lucide-react": "^0.577.0",
    "mailparser": "^3.9.9",
    "mathml2omml": "^0.5.0",
    "mdast-util-find-and-replace": "^3.0.2",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.10",
    "openai": "^6.38.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.6",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^16.5.4",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "sonner": "^2.0.7",
    "sqlite-vec": "^0.1.7-alpha.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0",
    "tsdav": "^2.2.2",
    "tw-animate-css": "^1.4.0",
    "unified": "^11.0.5",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  }
}
