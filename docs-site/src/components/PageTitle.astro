---
/**
 * PageTitle override: Aurora gradient on content page h1.
 */
---

<h1 id="_top" class="kb-page-title">{Astro.locals.starlightRoute.entry.data.title}</h1>

<style>
	.kb-page-title {
		margin-top: 1rem;
		font-size: var(--sl-text-h1);
		line-height: var(--sl-line-height-headings);
		font-weight: 700;
		background: linear-gradient(
			135deg,
			oklch(0.72 0.19 305) 0%,
			oklch(0.72 0.22 342) 50%,
			oklch(0.84 0.13 60) 100%
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	:root[data-theme='light'] .kb-page-title {
		background: linear-gradient(
			135deg,
			oklch(0.46 0.22 305) 0%,
			oklch(0.50 0.23 342) 50%,
			oklch(0.62 0.16 55) 100%
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
</style>
