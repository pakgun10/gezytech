---
/**
 * MobileTableOfContents override: Aurora-styled mobile TOC dropdown.
 */
import Default from '@astrojs/starlight/components/MobileTableOfContents.astro';
---

<div class="kb-mobile-toc">
	<Default><slot /></Default>
</div>

<style>
	.kb-mobile-toc {
		position: relative;
	}

	/* Summary / toggle button */
	:global(.kb-mobile-toc summary) {
		background: oklch(0.205 0.04 312 / 0.40) !important;
		backdrop-filter: blur(8px) saturate(160%);
		-webkit-backdrop-filter: blur(8px) saturate(160%);
		border: 1px solid oklch(0.72 0.19 305 / 0.12) !important;
		border-radius: 0.75rem !important;
		padding: 0.625rem 1rem !important;
		font-weight: 600 !important;
		font-size: 0.8125rem !important;
		transition: border-color 0.2s ease !important;
	}

	:global(.kb-mobile-toc summary:hover) {
		border-color: oklch(0.72 0.19 305 / 0.25) !important;
	}

	/* Dropdown panel */
	:global(.kb-mobile-toc details[open] > :not(summary)) {
		background: oklch(0.205 0.04 312 / 0.60) !important;
		backdrop-filter: blur(12px) saturate(180%);
		-webkit-backdrop-filter: blur(12px) saturate(180%);
		border: 1px solid oklch(0.72 0.19 305 / 0.10) !important;
		border-radius: 0.75rem !important;
		margin-top: 0.5rem !important;
	}

	/* Active link in mobile TOC */
	:global(.kb-mobile-toc a[aria-current='true']) {
		color: var(--sl-color-accent) !important;
		font-weight: 600;
		position: relative;
	}

	:global(.kb-mobile-toc a[aria-current='true'])::before {
		content: '';
		position: absolute;
		inset-block: 2px;
		inset-inline-start: 0;
		width: 2px;
		border-radius: 2px;
		background: linear-gradient(180deg, oklch(0.72 0.19 305), oklch(0.72 0.22 342));
	}

	:global(.kb-mobile-toc a:hover) {
		color: var(--sl-color-accent-high) !important;
		background: oklch(0.72 0.19 305 / 0.05) !important;
		border-radius: 0.375rem;
	}

	/* Light mode */
	:root[data-theme='light'] :global(.kb-mobile-toc summary) {
		background: oklch(0.99 0.006 310 / 0.60) !important;
		border-color: oklch(0.52 0.21 305 / 0.12) !important;
	}

	:root[data-theme='light'] :global(.kb-mobile-toc details[open] > :not(summary)) {
		background: oklch(0.99 0.006 310 / 0.70) !important;
		border-color: oklch(0.52 0.21 305 / 0.10) !important;
	}
</style>
