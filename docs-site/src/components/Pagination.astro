---
/**
 * Pagination override: glass-effect prev/next navigation cards.
 */
import Default from '@astrojs/starlight/components/Pagination.astro';
---

<div class="kb-pagination">
	<Default><slot /></Default>
</div>

<style>
	.kb-pagination {
		margin-top: 2rem;
		border-top: 1px solid oklch(0.72 0.19 305 / 0.10);
		padding-top: 1.5rem;
	}

	/* Glass card links */
	:global(.kb-pagination .pagination-links a) {
		background: oklch(0.205 0.04 312 / 0.40) !important;
		backdrop-filter: blur(8px) saturate(160%) !important;
		-webkit-backdrop-filter: blur(8px) saturate(160%) !important;
		border: 1px solid oklch(0.72 0.19 305 / 0.12) !important;
		border-radius: 0.75rem !important;
		transition: border-color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease !important;
	}

	:global(.kb-pagination .pagination-links a:hover) {
		border-color: oklch(0.72 0.19 305 / 0.30) !important;
		transform: translateY(-2px) !important;
		box-shadow: 0 4px 16px oklch(0.72 0.19 305 / 0.08) !important;
	}

	/* Link title with gradient */
	:global(.kb-pagination .link-title) {
		background: linear-gradient(
			135deg,
			oklch(0.72 0.19 305),
			oklch(0.72 0.22 342)
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		font-weight: 700 !important;
	}

	/* Light mode */
	:root[data-theme='light'] .kb-pagination {
		border-top-color: oklch(0.52 0.21 305 / 0.10);
	}

	:root[data-theme='light'] :global(.kb-pagination .pagination-links a) {
		background: oklch(0.99 0.006 310 / 0.50) !important;
		border-color: oklch(0.52 0.21 305 / 0.12) !important;
	}

	:root[data-theme='light'] :global(.kb-pagination .link-title) {
		background: linear-gradient(
			135deg,
			oklch(0.46 0.22 305),
			oklch(0.50 0.23 342)
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
</style>
