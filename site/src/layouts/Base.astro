---
import '../styles/global.css';
import {
  DEFAULT_LOCALE,
  LOCALES,
  OG_LOCALES,
  localePath,
  parseLocaleFromPath,
  type Locale,
} from '../i18n';
import { UMAMI_SCRIPT_URL, UMAMI_WEBSITE_ID } from '../config/analytics';

interface Props {
  /** Page-specific title. Rendered as-is when `titleSuffix` is false, otherwise
   *  suffixed with " · Hivekeep". Falls back to the brand default. */
  title?: string;
  description?: string;
  /** Path to an OG/Twitter image, relative to the site base or absolute. */
  ogImage?: string;
  /** Append " · Hivekeep" to the title. True by default; the home page sets it
   *  false so its title stays the standalone brand line. */
  titleSuffix?: boolean;
  /** Page locale (drives <html lang>, og:locale, hreflang alternates). */
  lang?: Locale;
}

const SITE_NAME = 'Hivekeep';
const DEFAULT_TITLE = 'Hivekeep · Your AI team. At home.';
const DEFAULT_DESCRIPTION =
  'A self-hosted team of AI agents that remember, collaborate, and build their own tools. One container, zero external infra. Your AI team, at home.';

const {
  title,
  description = DEFAULT_DESCRIPTION,
  ogImage,
  titleSuffix = true,
  lang = DEFAULT_LOCALE,
} = Astro.props;

// Final document title: brand default when no title is given, otherwise the
// page title with the brand suffix (unless the caller opted out, or the title
// already carries the brand so we don't print "Install Hivekeep · Hivekeep").
const alreadyBranded = !!title && new RegExp(`\\b${SITE_NAME}\\b`, 'i').test(title);
const pageTitle = title
  ? titleSuffix && !alreadyBranded
    ? `${title} · ${SITE_NAME}`
    : title
  : DEFAULT_TITLE;

// Absolute URLs. `Astro.site` is the origin (https://hivekeep.app);
// the configured base (/) is part of Astro.url.pathname, so resolving
// the current pathname against the site origin yields the full canonical URL.
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogImageURL = new URL(
  ogImage ?? `${import.meta.env.BASE_URL.replace(/\/$/, '')}/og-image.png`,
  Astro.site,
).href;

// hreflang alternates: same page in every locale + x-default (English).
// Derive the locale-free path from the URL so layouts don't need it as a prop.
const { path: basePath } = parseLocaleFromPath(Astro.url.pathname);
const alternates = LOCALES.map((l) => ({
  hreflang: l,
  href: new URL(localePath(l, basePath), Astro.site).href,
}));
const xDefaultHref = new URL(localePath(DEFAULT_LOCALE, basePath), Astro.site).href;
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- Mark JS active before paint so scroll-reveal elements can start hidden
       only when JS can reveal them (no-JS users see everything immediately). -->
  <script is:inline>document.documentElement.classList.add('js')</script>
  <!-- First-visit language auto-detect: if the visitor never picked a language
       (no hk-lang) and the browser prefers a locale we ship, jump to it before
       paint. Explicit switcher choices are persisted and always win. -->
  <script is:inline define:vars={{ locales: LOCALES, defaultLocale: DEFAULT_LOCALE, currentLang: lang }}>
    (function () {
      try {
        var saved = localStorage.getItem('hk-lang');
        if (saved !== null) return; // user already chose; respect it
        var prefs = navigator.languages || [navigator.language || ''];
        var best = null;
        for (var i = 0; i < prefs.length && !best; i++) {
          var p = String(prefs[i]);
          // exact match first (pt-BR, zh-CN), then base-language match (pt → pt-BR)
          for (var j = 0; j < locales.length && !best; j++) {
            if (p.toLowerCase() === locales[j].toLowerCase()) best = locales[j];
          }
          var basePart = p.split('-')[0].toLowerCase();
          for (var k = 0; k < locales.length && !best; k++) {
            if (locales[k].split('-')[0].toLowerCase() === basePart) best = locales[k];
          }
        }
        if (!best || best === currentLang) return;
        // strip the current locale prefix (if any) to get the locale-free path
        var path = location.pathname;
        for (var m = 0; m < locales.length; m++) {
          var pfx = '/' + locales[m];
          if (path === pfx || path.indexOf(pfx + '/') === 0) { path = path.slice(pfx.length) || '/'; break; }
        }
        var target = best === defaultLocale ? path : '/' + best + (path === '/' ? '/' : path);
        if (target !== location.pathname) {
          localStorage.setItem('hk-lang', best);
          location.replace(target + location.search + location.hash);
        }
      } catch (e) { /* storage blocked: stay on the requested page */ }
    })();
  </script>
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {alternates.map((a) => (
    <link rel="alternate" hreflang={a.hreflang} href={a.href} />
  ))}
  <link rel="alternate" hreflang="x-default" href={xDefaultHref} />
  {/* Same favicon set as the app (src/client/public) */}
  <link rel="icon" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.ico`} sizes="32x32" />
  <link rel="icon" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/hivekeep.svg`} type="image/svg+xml" />
  <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/apple-touch-icon.png`} />
  <meta name="theme-color" content="#0a0710" />
  <meta name="generator" content={Astro.generator} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={SITE_NAME} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Hivekeep · Your AI team. At home." />
  <meta property="og:locale" content={OG_LOCALES[lang]} />
  {LOCALES.filter((l) => l !== lang).map((l) => (
    <meta property="og:locale:alternate" content={OG_LOCALES[l]} />
  ))}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />
  <meta name="twitter:image:alt" content="Hivekeep · Your AI team. At home." />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

  {/* Privacy-friendly, cookieless analytics (self-hosted Umami). Production
       build only (so `astro dev` never tracks) and only when configured in
       src/config/analytics.ts. Umami auto-collects referrers + UTM campaign
       params; the `Install Copy` custom event (window.umami.track) measures
       install intent. No cookies, no personal data, no consent banner needed. */}
  {import.meta.env.PROD && UMAMI_SCRIPT_URL && UMAMI_WEBSITE_ID && (
    <script is:inline defer src={UMAMI_SCRIPT_URL} data-website-id={UMAMI_WEBSITE_ID}></script>
  )}
</head>
<body>
  <slot />
</body>
</html>
