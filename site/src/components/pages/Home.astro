<script>
  // Wire up click-to-copy on command blocks (`.cmd`). The command text is the
  // first span (minus the leading "$ "); `.cp` is the copy icon. The localized
  // aria-label is set in the markup; only fall back to English if it's missing.
  document.querySelectorAll<HTMLElement>('.cmd').forEach((cmd) => {
    const btn = cmd.querySelector<HTMLElement>('.cp')
    const code = cmd.querySelector<HTMLElement>('span:not(.cp)')
    if (!btn || !code) return
    btn.setAttribute('role', 'button')
    if (!btn.getAttribute('aria-label')) btn.setAttribute('aria-label', 'Copy command')
    btn.addEventListener('click', async () => {
      const text = (code.textContent || '').replace(/^\s*\$\s*/, '').trim()
      try {
        await navigator.clipboard.writeText(text)
      } catch {
        return
      }
      // Conversion signal: copying the install one-liner. Lets campaign
      // referrers be measured against real install intent, not just visits.
      try { (window as any).umami?.track('Install Copy', { source: 'home' }) } catch { /* analytics absent */ }
      btn.classList.add('copied')
      setTimeout(() => btn.classList.remove('copied'), 1500)
    })
  })
</script>

