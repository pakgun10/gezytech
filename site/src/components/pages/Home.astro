---
// Localized home page body. All copy comes from the locale dictionary; pure
// code (stats wiring, hues, channel slugs, comparison marks) stays here.
import Base from '../../layouts/Base.astro';
import Avatar from '../Avatar.astro';
import Providers from '../Providers.astro';
import AgentDemo from '../AgentDemo.tsx';
import QueenieOnboarding from '../QueenieOnboarding.tsx';
import MiniAppsMarquee from '../MiniAppsMarquee.astro';
import LangSwitcher from '../LangSwitcher.astro';
import Footer from '../Footer.astro';
import { Icon } from 'astro-icon/components';
import agents from '../../agents.json';
import stats from '../../data/stats.json';
import { LOCALES, LOCALE_LABELS, getDict, localePath, type Locale } from '../../i18n';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = getDict(lang);
// Localized agent-directory domains, keyed by agent name (fallback: agents.json).
const agentDomains: Record<string, string> = t.components.domains;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const installHref = `${base}${localePath(lang, '/install')}`;
const pluginsHref = `${base}${localePath(lang, '/plugins')}`;
const tourHref = `${base}${localePath(lang, '/tour')}`;
// Live GitHub stats baked in at deploy by the pages workflow (site/src/data/stats.json).
const repoVersion = stats.version;
const repoStars = stats.stars;
// Only show the count when it is a positive number. A silent stats-fetch failure
// in the pages workflow falls back to 0, and rendering "0" next to "Star on GitHub"
// reads as nobody starred it, so hide the badge entirely in that case.
const showStars = typeof repoStars === 'number' && repoStars > 0;
const starLabel = repoStars >= 1000 ? `${(repoStars / 1000).toFixed(1)}k` : String(repoStars);

// ── project health (derived from site/src/data/stats.json at build) ──────────
// Every value is "show only when meaningful": a silent stats-fetch failure in
// the pages workflow leaves placeholders (0 / '' / null), and we hide those
// rather than render a misleading "0 issues / no commits" state.
const releaseUrl = (stats as any).latestReleaseUrl || 'https://github.com/MarlBurroW/hivekeep/releases';
const openIssues = typeof (stats as any).openIssues === 'number' ? (stats as any).openIssues : 0;
const showOpenIssues = openIssues > 0;
const contributors = typeof (stats as any).contributors === 'number' ? (stats as any).contributors : 0;
const showContributors = contributors > 0;
const topContributors: { login: string; avatarUrl: string; htmlUrl: string }[] = Array.isArray((stats as any).topContributors)
  ? (stats as any).topContributors
  : [];

// CI status → green/red dot + label. Unknown/missing stays hidden.
const ciStatus = String((stats as any).ciStatus || '');
const ciState =
  ciStatus === 'success' ? { cls: 'ok', label: t.home.health.ciPassing }
  : ciStatus === 'failure' ? { cls: 'bad', label: t.home.health.ciFailing }
  : ciStatus ? { cls: 'warn', label: ciStatus }
  : null;

// "last commit Nd ago", computed at build from the ISO timestamp.
function relTime(iso: string | null | undefined): string | null {
  if (!iso) return null;
  const then = Date.parse(iso);
  if (Number.isNaN(then)) return null;
  const secs = Math.max(0, Math.round((Date.now() - then) / 1000));
  const mins = Math.round(secs / 60);
  const hrs = Math.round(mins / 60);
  const days = Math.round(hrs / 24);
  if (secs < 60) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  if (hrs < 24) return `${hrs}h ago`;
  if (days < 30) return `${days}d ago`;
  const months = Math.round(days / 30);
  if (months < 12) return `${months}mo ago`;
  return `${Math.round(months / 12)}y ago`;
}
const lastCommit = relTime((stats as any).lastCommitISO);

// Show the strip only if at least one tile has real data.
const showHealth = showStars || showOpenIssues || showContributors || !!ciState || !!lastCommit;
const HUES = [305, 40, 20, 330, 265, 210, 150, 55, 15, 235, 290, 30, 170, 95, 260, 50, 200, 120];
const channels = [
  ['telegram', 'Telegram'], ['whatsapp', 'WhatsApp'], ['slack', 'Slack'],
  ['discord', 'Discord'], ['signal', 'Signal'], ['matrix', 'Matrix'],
];

// Honest comparison against the closest self-hosted peers. Marks are best-effort
// from public docs (Jun 2026). Peers genuinely win/tie on several rows.
// Row labels live in the dictionary (t.home.why.rows); the marks are data.
const cmpCols = ['Hivekeep', 'OpenClaw', 'Hermes'];
const CMP_MARKS = [
  ['yes', 'yes', 'yes'],
  ['yes', 'yes', 'yes'],
  ['yes', 'yes', 'yes'],
  ['yes', 'no',  'par'],
  ['yes', 'par', 'yes'],
  ['yes', 'yes', 'yes'],
  ['yes', 'no',  'no'],
  ['yes', 'par', 'par'],
  ['yes', 'no',  'no'],
  ['yes', 'no',  'no'],
  ['yes', 'no',  'no'],
  ['yes', 'par', 'par'],
  ['yes', 'no',  'no'],
];
const cmpRows = t.home.why.rows.map((label, i) => [label, ...(CMP_MARKS[i] ?? ['no', 'no', 'no'])]);
const cmpIcon: Record<string, string> = { yes: 'lucide:check', par: 'lucide:minus', no: 'lucide:x' };

// ── "See more features" expandable grid (after section 07) ──────────────────
// Curated from the docs/spec/code feature inventory — every card maps to a real,
// shipped capability. Copy lives in the dictionary; icons ride along with it.
const fxCategories = t.home.morefx.categories;
const fxCount = fxCategories.reduce((n, c) => n + c.cards.length, 0);
---
<Base lang={lang} title={t.meta.home.title} titleSuffix={false} description={t.meta.home.description}>
  <!-- ===== top bar ===== -->
  <header class="topbar"><div class="wrap in">
    <div class="brand"><img class="brand-logo" src={`${base}/logo.svg`} width="28" height="28" alt="" /> Hivekeep</div>
    <nav id="site-nav">
      <a href="#memory">{t.nav.features}</a><a href="#household">{t.nav.household}</a>
      <a href="#why">{t.nav.why}</a><a href={tourHref}>{t.nav.tour}</a><a href={pluginsHref}>{t.nav.plugins}</a><a href={`${base}/docs/`}>{t.nav.docs}</a>
      <a href="https://github.com/MarlBurroW/hivekeep">{t.nav.github}</a>
    </nav>
    <div class="nav-actions">
      <LangSwitcher lang={lang} path="/" />
      <a class="btn btn-primary btn-sm" href={installHref}>{t.nav.getStarted}</a>
      <button class="nav-toggle" type="button" aria-label="Menu" aria-expanded="false" aria-controls="site-nav"><Icon name="lucide:menu" class="ic-menu" /><Icon name="lucide:x" class="ic-x" /></button>
    </div>
  </div></header>

  <!-- ===== hero ===== -->
  <section class="hero"><div class="comb" aria-hidden="true"><span class="comb-dim"></span><span class="comb-lit-clip"><span class="comb-lit"></span></span><canvas class="comb-pulse"></canvas></div><div class="glow a"></div><div class="glow b"></div>
    <div class="wrap">
      <span class="meta">Hivekeep v{repoVersion} · {t.home.hero.meta}</span>
      <div class="hero-grid">
        <div>
          <span class="kicker">{t.home.hero.kicker}</span>
          <h1 class="display">{t.home.hero.h1a}<br><span class="warm">{t.home.hero.h1b}</span></h1>
          <p class="sub" set:html={t.home.hero.sub} />
          <dl class="colophon">
            <div class="row"><span class="k">{t.home.hero.colophon.runsOnK}</span><span class="v">{t.home.hero.colophon.runsOnV}</span></div>
            <div class="row"><span class="k">{t.home.hero.colophon.infraK}</span><span class="v"><span class="amb">{t.home.hero.colophon.infraV}</span></span></div>
            <div class="row"><span class="k">{t.home.hero.colophon.setupK}</span><span class="v">{t.home.hero.colophon.setupV}</span></div>
            <div class="row"><span class="k">{t.home.hero.colophon.channelsK}</span><span class="v">{t.home.hero.colophon.channelsV}</span></div>
          </dl>
          <div class="cta">
            <a class="btn btn-primary" href={installHref}><Icon name="lucide:terminal" /> {t.home.hero.ctaStart}</a>
            <a class="link-mono" href="#demo">{t.home.hero.ctaDemo} <Icon name="lucide:play" /></a>
          </div>
        </div>

        <!-- interactive Agents panel: click a row to replay a scripted demo -->
        <AgentDemo client:load total={agents.length} labels={t.components.agentDemo} />
      </div>
    </div>

    <div class="strip"><div class="wrap strip-in">
      <span>{t.home.hero.everywhere}</span>
      {channels.map(([slug, label]) => (
        <span class="chan"><Icon name={`simple-icons:${slug}`} /> {label}</span>
      ))}
      <span class="chan"><Icon name="lucide:monitor-smartphone" /> {t.home.hero.webPwa}</span>
    </div></div>
  </section>

  <!-- ===== project health (live GitHub signals, baked at deploy) ===== -->
  {showHealth && (
    <section class="health"><div class="wrap">
      <div class="health-row">
        <span class="health-kicker"><Icon name="lucide:activity" /> {t.home.health.kicker}</span>
        <div class="health-tiles">
          <a class="htile" href={releaseUrl}>
            <span class="ht-ic"><Icon name="lucide:tag" /></span>
            <span class="ht-body"><span class="ht-val">v{repoVersion}</span><span class="ht-lab">{t.home.health.latestRelease}</span></span>
          </a>
          {ciState && (
            <span class="htile">
              <span class={`ht-ci ${ciState.cls}`}><span class="ci-dot"></span></span>
              <span class="ht-body"><span class="ht-val">{t.home.health.ciPrefix} {ciState.label}</span><span class="ht-lab">{t.home.health.mainBranch}</span></span>
            </span>
          )}
          {showStars && (
            <a class="htile" href="https://github.com/MarlBurroW/hivekeep">
              <span class="ht-ic"><Icon name="lucide:star" /></span>
              <span class="ht-body"><span class="ht-val">{starLabel}</span><span class="ht-lab">{t.home.health.stars}</span></span>
            </a>
          )}
          {showOpenIssues && (
            <a class="htile" href="https://github.com/MarlBurroW/hivekeep/issues">
              <span class="ht-ic"><Icon name="lucide:circle-dot" /></span>
              <span class="ht-body"><span class="ht-val">{openIssues}</span><span class="ht-lab">{openIssues === 1 ? t.home.health.openIssue : t.home.health.openIssues}</span></span>
            </a>
          )}
          {lastCommit && (
            <a class="htile" href="https://github.com/MarlBurroW/hivekeep/commits/main">
              <span class="ht-ic"><Icon name="lucide:git-commit-horizontal" /></span>
              <span class="ht-body"><span class="ht-val">{lastCommit}</span><span class="ht-lab">{t.home.health.lastCommit}</span></span>
            </a>
          )}
          {showContributors && (
            <a class="htile" href="https://github.com/MarlBurroW/hivekeep/graphs/contributors">
              {topContributors.length > 0 && (
                <span class="ht-faces">
                  {topContributors.map((c) => (
                    <img class="ht-face" src={c.avatarUrl} width="22" height="22" loading="lazy" alt={c.login} />
                  ))}
                </span>
              )}
              <span class="ht-body"><span class="ht-val">{contributors}</span><span class="ht-lab">{contributors === 1 ? t.home.health.contributor : t.home.health.contributors}</span></span>
            </a>
          )}
        </div>
      </div>
    </div></section>
  )}

  <!-- ===== install video ===== -->
  <section class="videoblock" id="demo"><div class="wrap">
    <div class="sec-head" style="text-align:center;max-width:60ch;margin:0 auto 30px">
      <span class="kicker" style="justify-content:center">{t.home.video.kicker}</span>
      <h2 class="display">{t.home.video.heading}</h2>
      <p style="margin:0 auto">{t.home.video.sub}</p>
    </div>
    <div class="videoframe">
      <video
        src={`${base}/videos/onboarding.mp4`}
        poster={`${base}/screenshots/onboarding-poster.jpg`}
        controls
        playsinline
        preload="metadata"
      ></video>
    </div>
  </div></section>

  <!-- ===== 01 memory ===== -->
  <div class="wrap" id="memory"><section class="section reveal">
    <div class="num"><div class="hexnum"><span class="n">01</span></div><small>{t.home.s1memory.stage}</small><span class="spine" aria-hidden="true"></span></div>
    <div class="body">
      <h2 class="display">{t.home.s1memory.heading}</h2>
      <div class="split2">
        <div>
          <p>{t.home.s1memory.p1}</p>
          <p>{t.home.s1memory.p2}</p>
          <div class="taglist"><span class="t"><Icon name="lucide:infinity" /> {t.home.s1memory.tagSession}</span><span class="t"><Icon name="lucide:users" /> {t.home.s1memory.tagHandoff}</span></div>
        </div>
        <div class="figure glass">
          <div class="cap"><span>{t.home.s1memory.figCap}</span><span class="amb">{t.home.s1memory.figTag}</span></div>
          <div class="figbody">
            <div class="mcard">
              <div class="mic"><Icon name="lucide:brain" /></div>
              <div class="mbody">
                <div class="mbadges">
                  <span class="mbadge cat">{t.home.s1memory.card1.cat}</span>
                  <span class="mbadge">{t.home.s1memory.card1.topic}</span>
                  <span class="mbadge star"><Icon name="lucide:star" /> 0.8</span>
                  <span class="mbadge ret"><Icon name="lucide:arrow-up-from-line" /> 4</span>
                </div>
                <div class="mtext">{t.home.s1memory.card1.text}</div>
              </div>
            </div>
            <div class="mcard">
              <div class="mic"><Icon name="lucide:brain" /></div>
              <div class="mbody">
                <div class="mbadges">
                  <span class="mbadge cat">{t.home.s1memory.card2.cat}</span>
                  <span class="mbadge">{t.home.s1memory.card2.topic}</span>
                  <span class="mbadge star"><Icon name="lucide:star" /> 0.6</span>
                </div>
                <div class="mtext">{t.home.s1memory.card2.text}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section></div>
  <!-- ===== 02 sovereign ===== -->
  <div class="wrap band" id="self-host"><section class="section reveal">
    <div class="num"><div class="hexnum"><span class="n">02</span></div><small>{t.home.s2sovereign.stage}</small><span class="spine" aria-hidden="true"></span></div>
    <div class="body">
      <h2 class="display">{t.home.s2sovereign.heading}</h2>
      <div class="split2">
        <div>
          <p>{t.home.s2sovereign.p1}</p>
          <p set:html={t.home.s2sovereign.p2} />
          <div class="term mono"><span class="c">$</span> docker run -d -p 3000:3000 -v hivekeep-data:/app/data ghcr.io/marlburrow/hivekeep<br /><span class="cmt">{t.home.s2sovereign.termComment}</span></div>
        </div>
        <dl class="specs">
          <div class="r"><dt>{t.home.s2sovereign.specs.footprintK}</dt><dd>{t.home.s2sovereign.specs.footprintV}</dd></div>
          <div class="r"><dt>{t.home.s2sovereign.specs.infraK}</dt><dd>{t.home.s2sovereign.specs.infraV}</dd></div>
          <div class="r"><dt>{t.home.s2sovereign.specs.secretsK}</dt><dd>{t.home.s2sovereign.specs.secretsV}</dd></div>
          <div class="r"><dt>{t.home.s2sovereign.specs.dataK}</dt><dd>{t.home.s2sovereign.specs.dataV}</dd></div>
        </dl>
      </div>
    </div>
  </section></div>
  <!-- ===== 03 secrets (vault placeholders) — dict key s3vault; the later sN
       dict keys keep their historical names, only the displayed numbers shift ===== -->
  <div class="wrap" id="secrets"><div class="comb" style="--comb-lit:radial-gradient(560px 380px at 80% 20%,#000 0%,transparent 62%),radial-gradient(520px 360px at 14% 80%,#000 0%,transparent 62%)" aria-hidden="true"><span class="comb-dim"></span><span class="comb-lit-clip"><span class="comb-lit"></span></span></div><section class="section reveal">
    <div class="num"><div class="hexnum"><span class="n">03</span></div><small>{t.home.s3vault.stage}</small><span class="spine" aria-hidden="true"></span></div>
    <div class="body">
      <h2 class="display">{t.home.s3vault.heading}</h2>
      <div class="split2">
        <div>
          <p set:html={t.home.s3vault.p1} />
          <p set:html={t.home.s3vault.p2} />
          <div class="taglist">
            <span class="t"><Icon name="lucide:crosshair" /> {t.home.s3vault.tagScoped}</span>
            <span class="t"><Icon name="lucide:eye" /> {t.home.s3vault.tagReveal}</span>
            <span class="t"><Icon name="lucide:eraser" /> {t.home.s3vault.tagScrub}</span>
          </div>
        </div>
        <div class="figure glass vaultfig">
          <div class="cap"><span>{t.home.s3vault.figCap}</span><span class="amb">{t.home.s3vault.figTag}</span></div>
          <div class="vf-body mono">
            <div class="vf-lab">{t.home.s3vault.figModel}</div>
            <div class="vf-code">POST api.github.com/repos<br /><span class="vf-dim">Authorization:</span> Bearer <span class="vf-ph">&#123;&#123;secret:GITHUB_TOKEN&#125;&#125;</span></div>
            <div class="vf-boundary"><span>{t.home.s3vault.figBoundary}</span></div>
            <div class="vf-lab">{t.home.s3vault.figWire}</div>
            <div class="vf-code"><span class="vf-dim">Authorization:</span> Bearer <span class="vf-real">ghp_••••••••••••••••</span></div>
            <div class="vf-guard"><Icon name="lucide:shield-check" /> <span set:html={t.home.s3vault.figGuard} /></div>
          </div>
        </div>
      </div>
    </div>
  </section></div>
  <!-- ===== 04 self-improving ===== -->
  <div class="wrap" id="extensible"><section class="section reveal">
    <div class="num"><div class="hexnum"><span class="n">04</span></div><small>{t.home.s3extensible.stage}</small><span class="spine" aria-hidden="true"></span></div>
    <div class="body">
      <h2 class="display">{t.home.s3extensible.heading}</h2>
      <div class="split2">
        <div class="shot">
          <div class="shot-inner">
            <img src={`${base}/screenshots/tool-rendered.png`} alt={t.home.s3extensible.shotAlt} loading="lazy" />
          </div>
        </div>
        <div>
          <p set:html={t.home.s3extensible.p1} />
          <p set:html={t.home.s3extensible.p2} />
          <div class="taglist">
            <span class="t"><Icon name="lucide:wrench" /> {t.home.s3extensible.tagCustomTools}</span>
            <span class="t"><Icon name="lucide:layout-dashboard" /> {t.home.s3extensible.tagMiniApps}</span>
            <span class="t"><Icon name="lucide:package" /> {t.home.s3extensible.tagNpm}</span>
            <span class="t"><Icon name="lucide:plug" /> {t.home.s3extensible.tagMcp}</span>
            <span class="t"><Icon name="lucide:toy-brick" /> {t.home.s3extensible.tagToolboxes}</span>
          </div>
        </div>
      </div>
    </div>
  </section></div>

  <!-- ===== mini-apps showcase (marquee) ===== -->
  <MiniAppsMarquee lang={lang} />

  <!-- ===== 04 everywhere ===== -->
  <div class="wrap band" id="channels"><section class="section reveal">
    <div class="num"><div class="hexnum"><span class="n">05</span></div><small>{t.home.s4channels.stage}</small><span class="spine" aria-hidden="true"></span></div>
    <div class="body">
      <h2 class="display">{t.home.s4channels.heading}</h2>
      <div class="split2">
        <div>
          <p set:html={t.home.s4channels.p1} />
          <div class="taglist">
            {channels.map(([slug, label]) => (
              <span class="t"><Icon name={`simple-icons:${slug}`} /> {label}</span>
            ))}
          </div>
        </div>
        <div class="shot">
          <div class="shot-inner">
            <img src={`${base}/screenshots/channel-multi-agent.png`} alt={t.home.s4channels.shotAlt} loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section></div>
  <!-- ===== 05 in your pocket (PWA) ===== -->
  <div class="wrap" id="pocket"><section class="section reveal">
    <div class="num"><div class="hexnum"><span class="n">06</span></div><small>{t.home.s5pocket.stage}</small><span class="spine" aria-hidden="true"></span></div>
    <div class="body">
      <h2 class="display">{t.home.s5pocket.heading}</h2>
      <div class="split2">
        <div>
          <p set:html={t.home.s5pocket.p1} />
          <p set:html={t.home.s5pocket.p2} />
          <div class="taglist">
            <span class="t"><Icon name="lucide:smartphone" /> {t.home.s5pocket.tagPwa}</span>
            <span class="t"><Icon name="lucide:monitor-smartphone" /> {t.home.s5pocket.tagDesktopMobile}</span>
            <span class="t"><Icon name="lucide:bell" /> {t.home.s5pocket.tagBadges}</span>
            <span class="t"><Icon name="lucide:mic" /> {t.home.s5pocket.tagVoice}</span>
          </div>
        </div>
        <div class="pocket-stage">
          <div class="phone" aria-label={t.home.s5pocket.phone.aria}>
            <div class="ph-screen">
              <span class="ph-island" aria-hidden="true"></span>
              <div class="ph-status mono"><span>21:37</span><span class="ph-st-ics"><Icon name="lucide:signal" /><Icon name="lucide:wifi" /><Icon name="lucide:battery-medium" /></span></div>
              <div class="ph-chat-head">
                <img src={`${base}/avatars/nest.jpg`} alt="" width="26" height="26" loading="lazy" />
                <span class="ph-nm">Nest</span>
                <span class="dm-chip"><span class="pip"></span> {t.home.s5pocket.phone.online}</span>
              </div>
              <div class="ph-chat">
                <div class="dm-row user"><div class="dm-bubble user">{t.home.s5pocket.phone.userBubble}</div></div>
                <div class="dm-row">
                  <div class="dm-col">
                    <div class="dm-tool"><span class="dm-tool-ic dm-t-config"><Icon name="lucide:thermometer" /></span><span class="dm-tool-nm">{t.home.s5pocket.phone.tool1Name}<span class="dm-tool-detail">{t.home.s5pocket.phone.tool1Detail}</span></span><span class="dm-tool-status"><Icon name="lucide:check" class="dm-ok" /></span></div>
                    <div class="dm-tool"><span class="dm-tool-ic dm-t-email"><Icon name="lucide:lamp" /></span><span class="dm-tool-nm">{t.home.s5pocket.phone.tool2Name}<span class="dm-tool-detail">{t.home.s5pocket.phone.tool2Detail}</span></span><span class="dm-tool-status"><Icon name="lucide:check" class="dm-ok" /></span></div>
                    <div class="dm-bubble agent" set:html={t.home.s5pocket.phone.agentBubble}></div>
                  </div>
                </div>
              </div>
              <div class="ph-composer">
                <div class="dm-input-box"><span class="dm-input-ph">{t.home.s5pocket.phone.inputPlaceholder}</span><span class="ph-mic"><Icon name="lucide:mic" /></span><span class="dm-send"><Icon name="lucide:arrow-up" /></span></div>
              </div>
              <span class="ph-homebar" aria-hidden="true"></span>
            </div>
