---
// Localized plugins pages: one static route per non-default locale.
import PluginsPage from '../../components/pages/PluginsPage.astro';
import { PREFIXED_LOCALES, type Locale } from '../../i18n';

export function getStaticPaths() {
  return PREFIXED_LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
---
<PluginsPage lang={lang as Locale} />
