---
// Localized tour pages: one static route per non-default locale (/fr/tour, …).
import TourPage from '../../components/pages/TourPage.astro';
import { PREFIXED_LOCALES, type Locale } from '../../i18n';

export function getStaticPaths() {
  return PREFIXED_LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
---
<TourPage lang={lang as Locale} />
