---
// Localized install pages: one static route per non-default locale (/fr/install, …).
import InstallPage from '../../components/pages/InstallPage.astro';
import { PREFIXED_LOCALES, type Locale } from '../../i18n';

export function getStaticPaths() {
  return PREFIXED_LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
---
<InstallPage lang={lang as Locale} />
