---
// Localized home pages: one static route per non-default locale (/fr/, /es/, …).
import Home from '../../components/pages/Home.astro';
import { PREFIXED_LOCALES, type Locale } from '../../i18n';

export function getStaticPaths() {
  return PREFIXED_LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
---
<Home lang={lang as Locale} />
